{
    "manifest_version": 3,
    "name": "BountySleuth - Web Sec Analyzer",
    "version": "3.3",
    "author": "Security0x0 Research And Development Private",
    "description": "Professional bug bounty companion v3.3. Universal scanner with WAF, CSRF, XSS, DOM Sinks, CORS, Cloud Detection, Source Maps, and Smart Payloads.",
    "icons": {
        "48": "icon.png",
        "128": "icon.png"
    },
    "permissions": [
        "activeTab",
        "webRequest",
        "storage",
        "scripting",
        "webNavigation",
        "downloads"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "BountySleuth Analyzer",
        "default_icon": "icon.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "bountysleuth@sagarbanwa.com",
            "strict_min_version": "109.0"
        }
    }
}